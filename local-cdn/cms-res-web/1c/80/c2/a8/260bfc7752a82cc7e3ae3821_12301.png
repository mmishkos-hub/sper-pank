<style>#skeleton .hug-mobile-16{height:16px}@media (min-width:577px){#skeleton .hug-tablet-24{height:24px}}#skeleton .layout{background-color:#fff;display:flex;flex-direction:column;flex:1 0 auto;font-family:SBSans,Arial,Helvetica,sans-serif;justify-content:space-between;max-width:100%;min-height:calc(100vh + env(safe-area-inset-top));padding-top:env(safe-area-inset-top);width:100%}@media (min-width:577px){#skeleton .layout{background-color:#f2f5f7}}#skeleton .layout-top{display:flex;flex-direction:column;height:100vh}@media (min-width:577px){#skeleton .layout-top{height:auto}}.layout-header{display:none;margin:0;padding:20px 0 40px}@media (min-width:577px){.layout-header{display:block;padding:80px 0 60px}}#skeleton .header{align-items:center;display:flex;flex-shrink:0;justify-content:center;padding:0;width:100%}#skeleton .header-image{background-color:#f2f5f7;border-radius:8px;height:15px;width:100px}@media (min-width:415px){#skeleton .header-image{height:30px;width:195px}}@media (min-width:577px){#skeleton .header-image{background-color:#fff}}#skeleton .layout-main{display:flex;flex-direction:column;justify-content:space-between;margin:0 auto 15px;max-width:100%;min-height:calc(100vh - 16px);padding-left:16px;padding-right:16px;position:relative;width:500px;z-index:3}@media (min-width:577px){#skeleton .layout-main{margin:0 auto 25px;padding:0}}#skeleton .layout-content{background-color:transparent;border-radius:0;display:flex;flex-direction:column;overflow:hidden;padding:0 0 28px;pointer-events:auto;position:relative;width:100%}@media (min-width:577px){#skeleton .layout-content{background-color:#fff;border-radius:24px;padding:24px}}#skeleton .mobile-banner{background-color:transparent;border-radius:0;display:flex;flex-direction:column;padding:0 0 28px;pointer-events:auto;position:relative;width:100%}@media (min-width:577px){#skeleton .mobile-banner{display:none;padding:24px}}#skeleton .mobile-banner-wrapper{background-color:transparent;display:flex;justify-content:left;margin:0 auto;min-height:102px;padding:0 0 24px;position:relative;width:90%}#skeleton .mobile-banner-content{align-items:center;display:flex;flex-direction:column;padding:0;width:100%}@media (max-height:599px){#skeleton .mobile-banner-image{height:180px;width:180px}}@media (min-height:600px) and (max-height:699px){#skeleton .mobile-banner-image{height:180px;width:180px}}@media (min-height:700px){#skeleton .mobile-banner-image{height:256px;width:256px}}#skeleton .at-rows{display:flex;gap:8px;flex-direction:column}#skeleton .at-row{display:flex;gap:8px}#skeleton .at-row-1>:first-child{-ms-flex-preferred-size:62%;flex-basis:62%}#skeleton .at-row-1>:last-child{-ms-flex-preferred-size:38%;flex-basis:38%}#skeleton .at-row-2>:first-child{-ms-flex-preferred-size:40%;flex-basis:40%}#skeleton .at-row-2>:last-child{-ms-flex-preferred-size:60%;flex-basis:60%}#skeleton .at-button{background-color:#f2f5f7;border:0;border-radius:16px;cursor:pointer;display:flex;flex:1 1 0px;flex-direction:column;justify-content:space-between;margin:0;min-height:132px;overflow:hidden;padding:16px 8px 16px 16px;transition:background-color .2s linear;user-select:none;width:100%}#skeleton .at-button-qr{display:none}@media (min-width:577px){#skeleton .at-button-qr{display:unset}}#skeleton .b-links{display:flex;flex-wrap:wrap;gap:16px;justify-content:space-between}#skeleton .b-link{background-color:#f5f5f5;border-radius:8px;height:20px}</style>
