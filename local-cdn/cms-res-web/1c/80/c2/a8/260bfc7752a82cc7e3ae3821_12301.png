owsers .layout-main{border-radius:24px;padding:24px}#unallowedbrowsers .layout-header{display:block;padding:80px 0 60px}#unallowedbrowsers .technical-error-text{font-size:20px;letter-spacing:-.45px;line-height:28px}#unallowedbrowsers .technical-error-description{font-size:15px;line-height:20px}#unallowedbrowsers .blocked-greetings-top{flex-direction:row;gap:20px}#unallowedbrowsers .blocked-greetings-icon{height:56px;min-width:56px}#unallowedbrowsers .blocked-greetings-icon svg{height:40px;min-width:40px}}#unallowedbrowsers .blocked-greetings-icon--red{border:1px solid rgb(227 85 2)}#unallowedbrowsers .blocked-greetings-icon--red path{fill:rgb(227 85 2)}#unallowedbrowsers .blocked-greetings-title{color:#000;display:flex;flex-direction:column;flex-grow:1;font-family:SBSansDisplay,Arial,Helvetica,sans-serif;font-size:30px;font-weight:600;gap:24px 0;justify-content:space-evenly;letter-spacing:.1px;line-height:36px;margin:-4px 0}#unallowedbrowsers .browsers{display:flex;gap:20px}#unallowedbrowsers .browsers-title{color:#000;font-size:20px;letter-spacing:-.1px;line-height:28px}#unallowedbrowsers .browser-link{border-radius:50%;display:block;height:44px;width:44px}#unallowedbrowsers .browser-link:focus-visible{outline:rgb(38 38 38) solid 2px;outline-offset:2px}#unallowedbrowsers .browser-link>svg{height:44px;width:44px}#unallowedbrowsers .hug-mobile-12{height:12px}#unallowedbrowsers .hug-mobile-20{height:20px}#unallowedbrowsers .hug-mobile-16{height:16px}@media (min-width:768px){#unallowedbrowsers .hug-tablet-20{height:20px}#unallowedbrowsers .hug-tablet-12{height:12px}}
